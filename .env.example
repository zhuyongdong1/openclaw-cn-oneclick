# Copy to .env (install.sh generates this for you)

APP_NAME=OpenClaw CN OneClick
APP_ENV=local

# API
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_URL=http://localhost:8080

# Security
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Initial admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Database
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://openclaw:change-me@db:5432/openclaw

# OpenClaw (gateway)
# Default: use published image (recommended for one-click).
# If you build locally, set: OPENCLAW_IMAGE=openclaw:local
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_CONFIG_DIR=./data/openclaw/config
OPENCLAW_WORKSPACE_DIR=./data/openclaw/workspace
